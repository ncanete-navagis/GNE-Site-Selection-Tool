# Database Credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_password
POSTGRES_DB=gne_db

# Application Database URL (matches credentials above, targeting 'db' service)
DATABASE_URL=postgresql://postgres:postgres_password@db:5432/gne_db

# LLM Configuration
LLM_PROVIDER=google
LLM_API_KEY=your_llm_api_key_here

# Application Settings
SCORING_RADIUS_M=5000
ALLOWED_ORIGINS=["http://localhost:3000"]
LOG_DIR=/var/log/gne
SECRET_KEY=your_secret_key_here
