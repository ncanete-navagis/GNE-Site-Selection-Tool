# ─────────────────────────────────────────────
# Backend API
# URL of the FastAPI backend. Change to your deployed URL in production.
# ─────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ─────────────────────────────────────────────
# Google OAuth 2.0
# The Client ID must match GOOGLE_CLIENT_ID in the backend .env.
# Obtain from: https://console.cloud.google.com/ → APIs & Services → Credentials
# Authorized origins must include: http://localhost:5173
# ─────────────────────────────────────────────
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# ─────────────────────────────────────────────
# Google Maps / Places
# Required for the interactive map and site analysis features.
# Enable: Maps JavaScript API, Places API (New)
# ─────────────────────────────────────────────
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ─────────────────────────────────────────────
# Gemini AI (frontend direct calls)
# ─────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
