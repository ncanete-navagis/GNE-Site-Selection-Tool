# ─────────────────────────────────────────────────────────────────────────────
# Root .env — Docker Compose variable interpolation
# ─────────────────────────────────────────────────────────────────────────────
# 1. Copy this file:   cp .env.example .env
# 2. Fill in your real values below.
# 3. NEVER commit .env — it is already in .gitignore.
#
# These values must match what is set in backend/.env so that Docker Compose
# can correctly wire the backend → db connection URL.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL credentials (must match backend/.env)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_db_password_here
POSTGRES_DB=gne_db

